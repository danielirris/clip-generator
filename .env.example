# ============================================================
#  clip-generator — variables de entorno
#  Copia este archivo a .env y rellena tu clave.
#  NUNCA subas el .env real al repositorio.
# ============================================================

# --- Clave de API (obligatoria) ---
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Modelos (puedes dejarlos por defecto) ---
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_ANALYZE_MODEL=gpt-4o-mini

# --- Especificación de los clips ---
NUM_CLIPS=5                # cuántos clips generar por compendio (3-5 típico)
DURACION_TOTAL_S=48        # duración de cada clip en segundos
BEAT_MIN_S=2               # duración mínima de cada fragmento/corte (s)
BEAT_MAX_S=4               # duración máxima de cada fragmento/corte (s)
MIN_FRAGMENTOS=50          # tamaño mínimo recomendado del pool de fragmentos
HOOK_BEATS=2               # nº de fragmentos "impactantes" al inicio de cada clip
MODO_FONDO=blur            # blur | crop | pad_negro
SUBTITULOS=true            # (interno) toggle de subtítulos del render
SUBTITULOS_RECORTES=false  # Apartado 1 (Recortes): SIN subtítulos (se ponen en el Apartado 2)

# --- Transiciones ---
TRANSICIONES=true          # aplicar transiciones entre fragmentos
TRANS_MIN=3                # nº mínimo de transiciones por clip
TRANS_MAX=6                # nº máximo de transiciones por clip
MODO_TRANSICION=variadas   # variadas | fundido | corte
TRANS_DUR_S=0.4            # duración del solape de cada transición

# --- Audio ---
QUITAR_AUDIO_ORIGINAL=true # los clips no llevan el audio de los videos (se usa la música subida)

# --- Remotion ---
REMOTION_EXPORT=true       # exportar un proyecto Remotion editable por job

# --- Recursos (estabilidad en VPS) ---
FFMPEG_THREADS=1           # hilos de FFmpeg (1 = menor pico de CPU/RAM en el VPS)

# --- Modo anuncio (proyecto Remotion por video) ---
WHATSAPP_LINK=https://wa.me/0000000000   # link del botón CTA (cámbialo por el tuyo)
CTA_TEXTO=Haz clic para conseguir el tuyo
MUSICA_VOLUMEN=0.18        # volumen base de la música (0-1)
MUSICA_VOLUMEN_DUCKING=0.08  # volumen de la música mientras habla la voz
RENDERIZAR_ANUNCIO=true    # renderizar el mp4 final (requiere Node + remotion-runtime)

# --- Semilla (reproducibilidad de cortes/transiciones) ---
SEED=1234

# --- Límites y recursos ---
MAX_UPLOAD_MB=2048         # tamaño máximo por archivo subido (MB)
RETENCION_HORAS=24         # borrar outputs con más de N horas

# --- Servidor ---
PORT=8000
