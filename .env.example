# ============================================================
#  clip-generator — variables de entorno
#  Copia este archivo a .env y rellena tu clave.
#  NUNCA subas el .env real al repositorio.
# ============================================================

# --- Clave de API (obligatoria) ---
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Modelos (puedes dejarlos por defecto) ---
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_ANALYZE_MODEL=gpt-4o-mini

# --- Especificación de los clips ---
NUM_CLIPS=5                # cuántos clips generar por compendio (3-5 típico)
DURACION_TOTAL_S=48        # duración de cada clip en segundos
DURACION_BEAT_S=2          # duración de cada fragmento (beat)
MIN_FRAGMENTOS=50          # tamaño mínimo recomendado del pool de fragmentos
HOOK_BEATS=2               # nº de fragmentos "impactantes" al inicio de cada clip
MODO_FONDO=blur            # blur | crop | pad_negro
SUBTITULOS=true            # true | false  (quemar subtítulos)

# --- Límites y recursos ---
MAX_UPLOAD_MB=2048         # tamaño máximo por archivo subido (MB)
RETENCION_HORAS=24         # borrar outputs con más de N horas

# --- Servidor ---
PORT=8000
