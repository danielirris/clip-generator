# ============================================================
#  clip-generator — variables de entorno
#  Copia este archivo a .env y rellena tus claves.
#  NUNCA subas el .env real al repositorio.
# ============================================================

# --- Claves de API (obligatorias) ---
# Groq: https://console.groq.com/keys
GROQ_API_KEY=
# Gemini (Google AI Studio): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Modelos (puedes dejarlos por defecto) ---
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Especificación del clip de salida ---
DURACION_TOTAL_S=48          # duración total objetivo en segundos
DURACION_BEAT_S=2            # duración de cada beat en segundos
MODO_FONDO=blur             # blur | crop | pad_negro
SUBTITULOS=true             # true | false  (quemar subtítulos)

# --- Límites y recursos ---
MAX_UPLOAD_MB=2048           # tamaño máximo de subida en MB
RETENCION_HORAS=24           # borrar outputs con más de N horas

# --- Servidor ---
PORT=8000
